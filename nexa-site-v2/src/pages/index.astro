---
import BaseLayout from "../layouts/BaseLayout.astro";
import DevDulIsland from "../components/DevDulIsland.astro";
import GlassTile from "../components/GlassTile.astro";
import NexaFace from "../components/NexaFace";
import SectionShell from "../components/SectionShell.astro";
import { launcherTiles } from "../data/tiles";
import { sections } from "../data/sections";
import { publicBoundaries } from "../data/publicBoundaries";
---

<BaseLayout>
  <main class="page-shell" id="top">
    <DevDulIsland />

    <section class="home-stage" aria-label="NeXa home">
      <div class="home-stack">
        <NexaFace client:load tiles={launcherTiles} />
      </div>
    </section>

    <div class="scroll-guide" aria-label="NeXa public sections">
      {
        sections.map((section) => (
          <SectionShell id={section.id} eyebrow={section.eyebrow} title={section.title} intro={section.intro}>
            {section.id === "public-boundaries" ? (
              <div class="boundary-list">
                {publicBoundaries.map((boundary) => (
                  <p>{boundary}</p>
                ))}
              </div>
            ) : section.id === "nexa-rove" ? (
              <div class="rove-section">
                <div class="rove-photo-grid" aria-label="NeXa RoVe public photos">
                  {section.photos?.map((photo) => (
                    <figure class="rove-photo">
                      <img src={photo.src} alt={photo.alt} loading="lazy" />
                      <figcaption>{photo.caption}</figcaption>
                    </figure>
                  ))}
                </div>
                <div class="tile-grid">
                  {section.points.map((point) => (
                    <GlassTile title={section.title} text={point} />
                  ))}
                </div>
                {section.codePreview && (
                  <article class="code-preview" aria-label="NeXa RoVe public code preview">
                    <p class="micro-label">{section.codePreview.title}</p>
                    <code>{section.codePreview.command}</code>
                    <p>{section.codePreview.description}</p>
                  </article>
                )}
                {section.docs && (
                  <div class="rove-docs" aria-label="NeXa RoVe public documents">
                    {section.docs.map((doc) => (
                      <a href={doc.href}>{doc.label}</a>
                    ))}
                  </div>
                )}
                {section.video && (
                  <figure class="rove-video" aria-label="NeXa RoVe public video">
                    <video controls preload="metadata" poster={section.video.poster}>
                      <source src={section.video.src} type="video/mp4" />
                    </video>
                    <figcaption>{section.video.caption}</figcaption>
                  </figure>
                )}
                {section.history && (
                  <div class="rove-history" aria-label="NeXa RoVe build story">
                    {section.history.map((item) => (
                      <article>
                        <p>{item}</p>
                      </article>
                    ))}
                  </div>
                )}
                <div class="rove-roadmap" aria-label="NeXa RoVe public roadmap">
                  {section.roadmap?.map((item, index) => (
                    <article>
                      <span>{String(index + 1).padStart(2, "0")}</span>
                      <p>{item}</p>
                    </article>
                  ))}
                </div>
                <nav class="section-nav" aria-label="NeXa RoVe related sections">
                  {section.related?.map((link) => (
                    <a href={link.href}>{link.label}</a>
                  ))}
                </nav>
              </div>
            ) : (
              <div class="tile-grid">
                {section.points.map((point) => (
                  <GlassTile title={section.title} text={point} />
                ))}
              </div>
            )}
          </SectionShell>
        ))
      }
    </div>
  </main>
</BaseLayout>
