---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "NeXa Public Site v2",
  description = "A public foundation for NeXa, with NeXa RoVe shown as the first physical prototype."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
